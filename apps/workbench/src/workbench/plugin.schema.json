{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tma.local/schemas/tma.workbench_plugin.v1.json",
  "title": "TMA Workbench Plugin Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "id", "name", "version", "entry", "surfaces", "engines", "permissions", "contributes"],
  "properties": {
    "protocol_version": { "const": "tma.workbench_plugin.v1" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$" },
    "entry": { "type": "string", "pattern": "^\\./(?!.*(?:^|/)\\.\\.(?:/|$))[^:]+$" },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["web_desktop", "desktop_shell", "web_tablet", "web_mobile"] }
    },
    "engines": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workbench_api", "design_system"],
      "properties": {
        "workbench_api": { "type": "string", "minLength": 1 },
        "design_system": { "type": "string", "minLength": 1 }
      }
    },
    "permissions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/namespacedIdentifier" }
    },
    "contributes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "navigation": { "type": "array", "items": { "$ref": "#/$defs/navigation" } },
        "routes": { "type": "array", "items": { "$ref": "#/$defs/route" } },
        "commands": { "type": "array", "items": { "$ref": "#/$defs/command" } }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "scope"],
      "properties": {
        "schema": { "type": "string", "pattern": "^\\./" },
        "scope": { "enum": ["organization", "workspace", "user"] }
      }
    }
  },
  "$defs": {
    "localIdentifier": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "namespacedIdentifier": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$" },
    "permissionList": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/namespacedIdentifier" } },
    "navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "group", "title", "route"],
      "properties": {
        "id": { "$ref": "#/$defs/localIdentifier" },
        "group": { "$ref": "#/$defs/localIdentifier" },
        "title": { "type": "string", "minLength": 1 },
        "route": { "type": "string", "pattern": "^/plugins/" },
        "order": { "type": "integer" }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "component"],
      "properties": {
        "id": { "$ref": "#/$defs/localIdentifier" },
        "path": { "type": "string", "pattern": "^/plugins/" },
        "component": { "type": "string", "minLength": 1 },
        "required_permissions": { "$ref": "#/$defs/permissionList" }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": { "$ref": "#/$defs/namespacedIdentifier" },
        "title": { "type": "string", "minLength": 1 },
        "risk": { "enum": ["read", "write", "exec", "external_effect"] },
        "required_permissions": { "$ref": "#/$defs/permissionList" },
        "contexts": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/namespacedIdentifier" } },
        "input_schema": { "type": "object" },
        "output_schema": { "type": "object" }
      }
    }
  }
}
