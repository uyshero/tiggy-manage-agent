TMA_ENV=development
TMA_HTTP_ADDR=:8080
TMA_DATABASE_URL=postgres://tma:tma@localhost:5432/tma?sslmode=disable
# Local development uses the migration owner above. Production must use a separate non-owner,
# non-superuser runtime role without BYPASSRLS; see docs/configuration.md.
TMA_BASE_URL=http://localhost:8080
# Required before using Settings > Environment Variables. Generate with: openssl rand -base64 32
# Use the same key on the server and any worker that executes encrypted tool work.
# TMA_ENV_ENCRYPTION_KEY=
# Unified user/API identity. disabled is allowed only outside production.
TMA_AUTH_MODE=disabled
# Recommended production mode: OIDC Discovery + asymmetric JWKS validation.
# TMA_AUTH_MODE=oidc
# TMA_AUTH_OIDC_ISSUER=https://identity.example.com
# TMA_AUTH_OIDC_AUDIENCE=tma-api
# Public OAuth client used by `tma auth login` Device Authorization Flow. No client secret.
# TMA_AUTH_OIDC_CLI_CLIENT_ID=tma-cli
# Optional when the provider supports standard Discovery.
# TMA_AUTH_OIDC_JWKS_URL=https://identity.example.com/.well-known/jwks.json
# TMA_AUTH_OIDC_SIGNING_ALGS=RS256,ES256
# TMA_AUTH_OIDC_HTTP_TIMEOUT_SECONDS=10
# TMA_AUTH_OIDC_REFRESH_INTERVAL_SECONDS=900
# TMA_AUTH_OIDC_MAX_STALE_SECONDS=86400
# Production OIDC must restrict tenants through allowed_workspace_ids or workspace group_mappings.
# Dot paths resolve nested claims such as realm_access.roles.
# TMA_AUTH_OIDC_CLAIM_MAPPING_JSON={"subject_claim":"sub","roles_claim":"realm_access.roles","groups_claim":"groups","role_mappings":{"tma-user":"member"},"group_mappings":{"finance-operators":{"organization_id":"org_finance","workspace_id":"wksp_finance","roles":["operator"]}},"allowed_workspace_ids":["wksp_finance"],"require_group_mapping":true}
# Optional built-in browser login using Authorization Code + PKCE and HttpOnly cookies.
# TMA_AUTH_OIDC_WEB_LOGIN_ENABLED=true
# TMA_AUTH_OIDC_WEB_CLIENT_ID=tma-web
# TMA_AUTH_OIDC_WEB_CLIENT_SECRET=
# TMA_AUTH_OIDC_WEB_REDIRECT_URL=http://localhost:8080/auth/callback
# TMA_AUTH_OIDC_WEB_POST_LOGOUT_URL=http://localhost:8080/app
# TMA_AUTH_OIDC_WEB_SESSION_SECRET=replace-with-at-least-32-random-bytes
# Local Keycloak Compose bootstrap credentials. Never reuse these in production.
# TMA_KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-random-admin-password
# TMA_KEYCLOAK_INITIAL_ADMIN_PASSWORD=replace-with-a-random-initial-user-password
# NetEase 163 and similar providers require a mailbox authorization code, not the account password.
# TMA_KEYCLOAK_SMTP_PASSWORD=replace-with-the-mailbox-authorization-code
# Optional public origins accepted for Cookie-authenticated writes behind a proxy.
# TMA_AUTH_COOKIE_TRUSTED_ORIGINS=https://tma.example.com
# Optional asynchronous OTLP/HTTP Logs export for authorization decisions.
# Production endpoints must use HTTPS. Use a dedicated least-privilege collector token.
# TMA_SECURITY_AUDIT_OTLP_ENDPOINT=https://otel-collector.example.com:4318
# TMA_SECURITY_AUDIT_OTLP_TOKEN=replace-with-a-security-audit-export-token
# Single-key compatibility mode. Required in production unless the rotating keyring below is configured.
# TMA_SECURITY_AUDIT_INTEGRITY_KEY=replace-with-at-least-32-random-bytes
# Recommended rotating keyring. KEY_ID selects the signing key; all entries remain valid for verification.
# TMA_SECURITY_AUDIT_INTEGRITY_KEY_ID=2026-07
# TMA_SECURITY_AUDIT_INTEGRITY_KEYS_JSON={"2026-01":"replace-with-previous-32-byte-key","2026-07":"replace-with-current-32-byte-key"}
# Durable PostgreSQL outbox is the default and is mandatory in production.
# TMA_SECURITY_AUDIT_DURABLE=true
# TMA_SECURITY_AUDIT_QUEUE_SIZE=2048
# TMA_SECURITY_AUDIT_BATCH_SIZE=100
# TMA_SECURITY_AUDIT_FLUSH_INTERVAL_MS=1000
# TMA_SECURITY_AUDIT_HTTP_TIMEOUT_SECONDS=10
# TMA_SECURITY_AUDIT_WORKER_INTERVAL_MS=1000
# TMA_SECURITY_AUDIT_LEASE_DURATION_MS=30000
# TMA_SECURITY_AUDIT_MAX_ATTEMPTS=8
# TMA_SECURITY_AUDIT_RETRY_INITIAL_DELAY_MS=1000
# TMA_SECURITY_AUDIT_RETRY_MAX_DELAY_MS=300000
# TMA_SECURITY_AUDIT_RETENTION_DAYS=90
# TMA_SECURITY_AUDIT_PRUNE_INTERVAL_MS=3600000
# TMA_SECURITY_AUDIT_PRUNE_LIMIT=1000
# JWT HS256 mode. Production requires a secret of at least 32 bytes plus issuer and audience.
# TMA_AUTH_MODE=jwt
# TMA_AUTH_JWT_SECRET=replace-with-at-least-32-random-bytes
# TMA_AUTH_JWT_ISSUER=https://identity.example.com
# TMA_AUTH_JWT_AUDIENCE=tma-api
# Trusted gateway mode. TMA validates both the direct proxy IP and this shared header secret.
# TMA_AUTH_MODE=gateway
# TMA_AUTH_GATEWAY_TOKEN=replace-with-at-least-32-random-bytes
# TMA_AUTH_GATEWAY_TRUSTED_CIDRS=127.0.0.0/8,10.0.0.0/8
# CLI JWT or legacy control token sent as Authorization: Bearer ...
# TMA_AUTH_TOKEN=
# Server-side token required by worker consumer endpoints when set.
# TMA_WORKER_AUTH_TOKEN=change-me
# Workspace bound to the shared worker service credential.
TMA_WORKER_AUTH_WORKSPACE_ID=wksp_default
# Optional migration-only control token. Prefer JWT operator/admin roles.
# TMA_WORKER_CONTROL_AUTH_TOKEN=change-me-control
# Worker-side token sent as Authorization: Bearer ...
# TMA_WORKER_TOKEN=change-me
TMA_WORKER_WORKSPACE_ID=wksp_default
TMA_WORKER_TYPE=local
TMA_WORKER_LEASE_SECONDS=60
TMA_WORKER_POLL_INTERVAL=3s
TMA_WORKER_HEARTBEAT_INTERVAL=30s
TMA_TURN_QUEUE_SIZE=16
TMA_TURN_WORKER_COUNT=4
TMA_TURN_POLL_INTERVAL_MS=500
TMA_TURN_LEASE_DURATION_MS=10000
TMA_TURN_HEARTBEAT_INTERVAL_MS=1000
# TMA_TURN_TIMEOUT_MS=7200000
TMA_MAX_TOOL_ROUNDS=100
# TMA_AGENT_CORE_ENABLED=false
# TMA_AGENT_CORE_ROLLOUT_PERCENT=100
# TMA_AGENT_CORE_WORKSPACE_IDS=
# TMA_AGENT_CORE_AGENT_IDS=
# Server-side MCP stdio host process lifecycle and capacity.
# TMA_MCP_STDIO_HOST_IDLE_TIMEOUT_SECONDS=600
# TMA_MCP_STDIO_HOST_SWEEP_INTERVAL_SECONDS=60
# TMA_MCP_STDIO_HOST_MAX_SESSIONS=64
# Server-side Streamable HTTP MCP session lifecycle and capacity.
# TMA_MCP_HTTP_HOST_IDLE_TIMEOUT_SECONDS=600
# TMA_MCP_HTTP_HOST_SWEEP_INTERVAL_SECONDS=60
# TMA_MCP_HTTP_HOST_MAX_SESSIONS=64
# Remote MCP egress is HTTPS-only and blocks private/special-use addresses by default.
# TMA_MCP_HTTP_EGRESS_ALLOW_HTTP=false
# TMA_MCP_HTTP_EGRESS_ALLOW_PRIVATE_NETWORKS=false
# TMA_MCP_HTTP_EGRESS_ALLOWED_HOSTS=mcp.example.com,*.mcp.example.com
# TMA_MCP_HTTP_EGRESS_ALLOWED_CIDRS=10.20.0.0/16,fd20::/64
# Optional PEM bundle appended to the system trust store for private MCP CAs.
# TMA_MCP_HTTP_CA_BUNDLE=/etc/tma/mcp-ca.pem
TMA_LLM_PROVIDER=fake
TMA_LLM_MODEL=fake-demo
# TMA_CLOUD_SANDBOX_CONTAINER_IDLE_TTL_SECONDS=1800
# TMA_CLOUD_SANDBOX_CONTAINER_MAX_LIFETIME_SECONDS=14400
# TMA_CLOUD_SANDBOX_CONTAINER_CLEANUP_INTERVAL_SECONDS=60
# TMA_LLM_PROVIDER=volcengine-agent-plan
# TMA_LLM_PROVIDER_TYPE=openai
# TMA_LLM_MODEL=gpt-4o-mini
# TMA_LLM_BASE_URL=https://api.openai.com/v1
# TMA_LLM_API_KEY_ENV=TMA_LLM_API_KEY
# TMA_LLM_API_KEY=
# TMA_LLM_MAX_ATTEMPTS=3
# TMA_LLM_RETRY_BASE_DELAY_MS=250
# Optional: enables GitHub code search, private repository reads, and higher rate limits for skills.discover/preview/install.
# TMA_SKILLS_GITHUB_TOKEN=
# Optional global Skills Marketplace policy. Empty values keep backward-compatible permissive behavior.
# TMA_SKILLS_GITHUB_ALLOWED_OWNERS=anthropics,acme
# TMA_SKILLS_GITHUB_ALLOWED_REPOSITORIES=trusted/special-skill
# TMA_SKILLS_GITHUB_REQUIRE_COMMIT_SHA=false
# TMA_SKILLS_ALLOWED_LICENSES=MIT,Apache-2.0
# TMA_SKILLS_DENIED_LICENSES=GPL-3.0,Proprietary
# TMA_SKILLS_REQUIRE_LICENSE=false
# TMA_SKILLS_REQUIRE_ATTESTATION=false
# JSON object: key id -> base64 Ed25519 public key.
# TMA_SKILLS_TRUSTED_ATTESTATION_KEYS={"release":"base64-public-key"}
# Empty, medium, high, or critical. Empty reports findings without blocking.
# TMA_SKILLS_STATIC_SCAN_BLOCK_SEVERITY=
# External malware scanner. builtin keeps deterministic local scanning only.
# External Binary Scanner / ClamAV is deferred. Current runtime uses builtin only.
# Server fallback retention policy. Both policy and worker default to disabled.
# TMA_SKILLS_ASSET_RETENTION_ENABLED=false
# TMA_SKILLS_ASSET_RETENTION_DAYS=30
# TMA_SKILLS_ASSET_GC_DELETE_LIMIT=100
# TMA_SKILLS_ASSET_GC_WORKER_ENABLED=false
# TMA_SKILLS_ASSET_GC_WORKER_INTERVAL_SECONDS=86400
TMA_OBJECT_STORAGE_PROVIDER=localfs
TMA_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
TMA_OBJECT_STORAGE_REGION=local
TMA_OBJECT_STORAGE_BUCKET=tma-artifacts
TMA_OBJECT_STORAGE_ROOT_DIR=/private/tmp/tma-object-store
TMA_OBJECT_STORAGE_ACCESS_KEY=tma
TMA_OBJECT_STORAGE_SECRET_KEY=tma-secret
TMA_OBJECT_STORAGE_USE_PATH_STYLE=true
# cloud_sandbox is the default tool runtime. ROOT is an isolation base; TMA mounts
# a workspace_id + owner_id + session_id scoped child, never ROOT itself.
# TMA_CLOUD_SANDBOX_ROOT=/private/tmp/tma-cloud-sandbox-workspaces
# TMA_CLOUD_SANDBOX_IMAGE=coolfan1024/onlyboxes-runtime:default
# browser.* uses a separate container scope and defaults to this Playwright image.
TMA_BROWSER_SANDBOX_IMAGE=tma-browser-sandbox:playwright
# Browser containers need more headroom than the 512m default scope.
TMA_BROWSER_SANDBOX_MEMORY=1g
# TMA_CLOUD_SANDBOX_ALLOW_NETWORK=true
# TMA_CLOUD_SANDBOX_DATA_ROOT=/private/tmp/tma-cloud-sandbox-data
# TMA_CLOUD_SANDBOX_DATA_TTL_SECONDS=14400
# Keep server-local local_system fallback disabled outside trusted dev.
# Real local_system execution should normally come from an online tma-worker.
# TMA_ALLOW_SERVER_LOCAL_SYSTEM=false
# Web search providers. If TMA_WEB_SEARCH_PROVIDERS is empty, configured-key
# providers are tried before the local SearXNG fallback.
# TMA_WEB_SEARCH_PROVIDERS=
# TMA_WEB_SEARXNG_BASE_URL=http://localhost:8180
# TMA_WEB_TAVILY_API_KEY=
# TMA_WEB_BRAVE_API_KEY=
# TMA_WEB_EXA_API_KEY=
# TMA_WEB_BAIDU_API_KEY=
# TMA_WEB_BAIDU_BASE_URL=https://qianfan.baidubce.com/v2/ai_search
# TMA_WEB_SEARCH1API_API_KEY=
# TMA_WEB_BROWSERLESS_BASE_URL=https://chrome.browserless.io/content
# TMA_WEB_BROWSERLESS_API_KEY=
# TMA_WEB_BROWSERLESS_PRIORITY=after_naive
# TMA_WEB_BROWSERLESS_WAIT_SELECTOR=
# TMA_WEB_BROWSERLESS_WAIT_TIMEOUT_MS=1200
# TMA_WEB_BROWSERLESS_WAIT_SELECTOR_TIMEOUT_MS=8000
# TMA_WEB_BROWSERLESS_GOTO_TIMEOUT_MS=15000
# TMA_WEB_BROWSERLESS_REQUEST_TIMEOUT_MS=30000
# TMA_WEB_BROWSERLESS_WAIT_UNTIL=networkidle0
# TMA_WEB_BROWSERLESS_USER_AGENT=
# TMA_WEB_BROWSERLESS_REJECT_RESOURCE_TYPES=image,media,font,stylesheet
# TMA_WEB_BROWSERLESS_BEST_ATTEMPT=true
