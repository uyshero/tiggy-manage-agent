# Store this file as deploy/docker/.env.production with mode 0600.
TMA_POSTGRES_OWNER_PASSWORD=replace-with-url-safe-owner-password
TMA_RUNTIME_DB_PASSWORD=replace-with-url-safe-runtime-password
TMA_DOCKER_GID=999
TMA_HTTP_BIND=127.0.0.1
TMA_HTTP_PORT=8080

TMA_ENV=production
TMA_HTTP_ADDR=:8080

# OIDC resource-server configuration. Replace every example value.
TMA_AUTH_MODE=oidc
TMA_AUTH_OIDC_ISSUER=https://identity.example.com
TMA_AUTH_OIDC_AUDIENCE=tma-api
TMA_AUTH_OIDC_CLI_CLIENT_ID=tma-cli
TMA_AUTH_OIDC_SIGNING_ALGS=RS256,ES256
TMA_AUTH_OIDC_CLAIM_MAPPING_JSON={"subject_claim":"sub","roles_claim":"roles","workspace_claim":"workspace_id","owner_claim":"sub","allowed_workspace_ids":["wksp_default"]}
TMA_AUTH_COOKIE_TRUSTED_ORIGINS=https://tma.example.com

# Worker consumer identity is mandatory in production even when no worker is enabled.
TMA_WORKER_AUTH_TOKEN=replace-with-a-random-worker-token
TMA_WORKER_AUTH_WORKSPACE_ID=wksp_default
TMA_WORKER_CONTROL_AUTH_TOKEN=replace-with-a-separate-control-token

# S3-compatible object storage. Pre-create the bucket and grant object CRUD.
TMA_OBJECT_STORAGE_PROVIDER=s3
TMA_OBJECT_STORAGE_ENDPOINT=https://s3.example.com
TMA_OBJECT_STORAGE_REGION=us-east-1
TMA_OBJECT_STORAGE_BUCKET=tma-artifacts
TMA_OBJECT_STORAGE_ACCESS_KEY=replace-with-access-key
TMA_OBJECT_STORAGE_SECRET_KEY=replace-with-secret-key
TMA_OBJECT_STORAGE_USE_PATH_STYLE=false

# Default OpenAI-compatible model provider.
TMA_LLM_PROVIDER=enterprise-openai
TMA_LLM_PROVIDER_TYPE=openai
TMA_LLM_MODEL=replace-with-model
TMA_LLM_BASE_URL=https://llm-gateway.example.com/v1
TMA_LLM_API_KEY_ENV=TMA_LLM_API_KEY
TMA_LLM_API_KEY=replace-with-llm-key

# Docker single-host sandbox paths must be the same inside the Server container
# and on the Docker host because the host daemon resolves bind-mount paths.
TMA_TOOL_RUNTIME=cloud_sandbox
TMA_CLOUD_SANDBOX_ROOT=/var/lib/tma/workspaces
TMA_CLOUD_SANDBOX_DATA_ROOT=/var/lib/tma/data
TMA_CLOUD_SANDBOX_IMAGE=coolfan1024/onlyboxes-runtime:default
TMA_BROWSER_GATEWAY_IMAGE=tma-browser-gateway:production
TMA_BROWSER_WORKER_IMAGE=tma-browser-worker:production
TMA_BROWSER_GATEWAY_SERVICE_SECRET=replace-with-openssl-rand-hex-32-output
TMA_BROWSER_AUTH_MODE=tma
TMA_BROWSER_MAX_SESSIONS_PER_WORKSPACE=4
TMA_BROWSER_IDLE_TTL_SECONDS=300
TMA_BROWSER_TRUSTED_ORIGINS=https://tma.example.com
TMA_CLOUD_SANDBOX_ALLOW_NETWORK=false
TMA_ALLOW_SERVER_LOCAL_SYSTEM=false

# Required only when managed environment variables are used by worker execution.
TMA_ENV_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32-output
